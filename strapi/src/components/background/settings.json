{
  "collectionName": "components_background_settings",
  "info": {
    "displayName": "Background Settings",
    "description": "Configurable background options with light/dark mode support"
  },
  "options": {},
  "attributes": {
    "type": {
      "type": "enumeration",
      "enum": ["color", "gradient", "image", "pattern", "preset"],
      "default": "preset",
      "required": true
    },
    "preset": {
      "type": "enumeration",
      "enum": ["dark-elegant", "purple-theme", "sunset", "ocean", "cosmic", "aurora"]
    },
    "lightColor": {
      "type": "string",
      "regex": "^#[0-9A-Fa-f]{6}$"
    },
    "darkColor": {
      "type": "string",
      "regex": "^#[0-9A-Fa-f]{6}$"
    },
    "lightGradient": {
      "type": "text"
    },
    "darkGradient": {
      "type": "text"
    },
    "lightImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "darkImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "lightPattern": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "darkPattern": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "opacity": {
      "type": "decimal",
      "min": 0,
      "max": 1,
      "default": 1
    },
    "overlay": {
      "type": "boolean",
      "default": false
    },
    "overlayOpacity": {
      "type": "decimal",
      "min": 0,
      "max": 1,
      "default": 0.3
    }
  }
}
